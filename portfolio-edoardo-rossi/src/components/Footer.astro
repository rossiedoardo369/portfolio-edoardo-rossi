---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container bar">
    <p class="mono small">© {year} Edoardo Rossi</p>
    <ul class="links">
      <li><a href="https://www.linkedin.com/in/rossiedoardo369" target="_blank" rel="noopener">LinkedIn</a></li>
      <li><a href="mailto:rossi.edoardo369@gmail.com">Email</a></li>
    </ul>
  </div>
</footer>

<style>
  .site-footer {
    border-top: var(--border);
    margin-top: var(--space-6);
  }
  .bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: var(--space-3);
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .small { font-size: 0.85rem; color: var(--color-ink-soft); margin: 0; }
  .links {
    display: flex;
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .links a { font-size: 0.9rem; }
</style>
