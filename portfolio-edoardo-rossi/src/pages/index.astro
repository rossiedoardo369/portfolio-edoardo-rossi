---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const proof = [
  {
    metric: '13,55×',
    label: 'ROAS',
    context: 'Programma di eventi ricorrenti su una rete di 6 sedi odontoiatriche — 2024',
  },
  {
    metric: '83%',
    label: 'tasso di chiusura post-visita',
    context: 'Posizionamento clinico-comunicativo costruito per una patologia complessa (parodontite)',
  },
  {
    metric: '+600%',
    label: 'fatturato su una linea di trattamento',
    context: 'Da circa 17.000€ a oltre 120.000€ in un anno, 2024 → 2025',
  },
];

const steps = [
  {
    n: '01',
    title: 'Strategia',
    body: 'Discovery diretta con il cliente: individuo il posizionamento e l’obiettivo di business reale, non solo quello pubblicitario.',
  },
  {
    n: '02',
    title: 'Esecuzione',
    body: 'Creatività, struttura della campagna, automazioni e integrazione con CRM e segreteria — dal primo contatto in poi.',
  },
  {
    n: '03',
    title: 'Misurazione',
    body: 'Reportistica che risale fino al risultato di business — paziente, fatturato, ritorno reale — non si ferma al click.',
  },
];
---
<BaseLayout
  title="Home"
  description="Performance Marketing & Digital Strategy Specialist — campagne Google e Meta misurate dal primo contatto al risultato di business."
>
  <section class="hero container">
    <p class="eyebrow">Performance Marketing &amp; Digital Strategy Specialist</p>
    <h1>Ogni euro speso in advertising dovrebbe poter rispondere a una domanda: cosa ha prodotto, esattamente?</h1>
    <p class="lede">
      Gestisco campagne Google e Meta per aziende del settore sanitario, dal primo contatto
      pubblicitario fino al paziente in poltrona — con la reportistica a dimostrarlo, non solo a raccontarlo.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href={`${base}work/`}>Guarda i case study</a>
      <a class="btn btn-ghost" href={`${base}contact/`}>Contattami</a>
    </div>
  </section>

  <section class="proof container" aria-label="Risultati principali">
    {proof.map((item) => (
      <article class="proof-card">
        <p class="mono metric">{item.metric}</p>
        <p class="proof-label">{item.label}</p>
        <p class="proof-context">{item.context}</p>
      </article>
    ))}
  </section>

  <section class="how container">
    <h2>Come lavoro</h2>
    <ol class="steps">
      {steps.map((step) => (
        <li>
          <span class="mono step-n">{step.n}</span>
          <div>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="closing container">
    <h2>Cinque progetti, cinque sfide diverse</h2>
    <p>
      Rete multi-sede da misurare end-to-end, posizionamento clinico da costruire da zero,
      automazione di un CRM per non disperdere lead: ogni caso studio affronta un problema
      diverso, con lo stesso metodo.
    </p>
    <a class="btn btn-primary" href={`${base}work/`}>Vai ai lavori selezionati →</a>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-5);
    max-width: 46rem;
  }
  .lede {
    font-size: 1.15rem;
    max-width: 38rem;
  }
  .cta-row {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-3);
  }
  .btn {
    display: inline-block;
    padding: 0.7rem 1.3rem;
    border-radius: var(--radius);
    text-decoration: none;
    font-size: 0.95rem;
    border: var(--border);
  }
  .btn-primary {
    background: var(--color-ink);
    color: var(--color-bg);
    border-color: var(--color-ink);
  }
  .btn-primary:hover { background: var(--color-accent); border-color: var(--color-accent); }
  .btn-ghost { color: var(--color-ink); }

  .proof {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    padding-block: var(--space-4) var(--space-6);
    border-top: var(--border);
    border-bottom: var(--border);
  }
  .proof-card {
    padding: var(--space-3);
    background: var(--color-surface);
    border: var(--border);
  }
  .metric {
    font-size: 2.1rem;
    font-weight: 500;
    color: var(--color-accent);
    margin: 0;
  }
  .proof-label {
    font-family: var(--font-display);
    font-size: 0.95rem;
    margin: 0.2rem 0 0.6rem 0;
  }
  .proof-context {
    font-size: 0.85rem;
    color: var(--color-ink-soft);
    margin: 0;
  }

  .how { padding-block: var(--space-6); }
  .steps {
    list-style: none;
    margin: var(--space-3) 0 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .steps li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: var(--space-2);
    border-top: var(--border);
    padding-top: var(--space-3);
  }
  .step-n { color: var(--color-caution); font-size: 1rem; }
  .steps h3 { margin-bottom: 0.3rem; }
  .steps p { margin: 0; }

  .closing {
    padding-block: var(--space-6);
    max-width: 40rem;
  }

  @media (max-width: 780px) {
    .proof { grid-template-columns: 1fr; }
  }
</style>
